# Copia este archivo como .env y reemplaza todos los valores sensibles.
FLASK_SECRET_KEY=genera-una-clave-aleatoria-larga
ADMIN_INITIAL_PASSWORD=define-una-clave-inicial-segura
SESSION_COOKIE_SECURE=false
MAX_UPLOAD_BYTES=5242880
LOGIN_MAX_INTENTOS=5
LOGIN_VENTANA_SEGUNDOS=900

LSCC_DB=lscc.db
MQTT_BROKER=127.0.0.1
MQTT_PORT=1883
MQTT_USER=usuario_mqtt
MQTT_PASSWORD=clave_mqtt

# Índice DirectShow de la cámara física (usa test_camaras.py para identificarlo).
USB_CAMERA_INDEX=0
MQTT_TLS=false
MQTT_CA_CERT=certs/ca.crt
MQTT_CERTFILE=
MQTT_KEYFILE=
MQTT_KEEPALIVE=60
DEVICE_OFFLINE_SECONDS=30

# Bot de WhatsApp (microservicio Node.js en whatsapp_bot/, ver whatsapp_bot/README.md)
WHATSAPP_BOT_URL=http://127.0.0.1:3001
WHATSAPP_BOT_TOKEN=define-un-token-compartido-largo
